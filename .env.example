APP_NAME=Go API Starter Kit
APP_DEBUG=true
FRONTEND_BASE_URL=http://localhost:8080

SERVER_PORT=8080
SERVER_CORS_ORIGINS=http://localhost:8080
SERVER_READ_HEADER_TIMEOUT=10s

LOG_LEVEL=info
LOG_FORMAT=json

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=gsk

AUTH_LOGIN_LIMIT_ATTEMPTS=5
AUTH_LOGIN_LIMIT_WINDOW=10m
AUTH_LOGIN_LOCKOUT_THRESHOLD=5
AUTH_LOGIN_LOCKOUT_DURATION=15m
AUTH_REFRESH_LIMIT_ATTEMPTS=20
AUTH_REFRESH_LIMIT_WINDOW=10m

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=go_starter_kit

JWT_ACCESS_SECRET=secret_key
JWT_REFRESH_SECRET=secret_key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=168h

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_TLS_MODE=starttls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=test@example.com
MAIL_FROM_NAME=Go API Starter Kit

OTEL_ENABLED=true
OTEL_SERVICE_NAME=go-starter-kit
OTEL_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER_RATIO=1.0
OTEL_EXPORT_TIMEOUT=5s