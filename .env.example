APP_NAME=go_starter_kit
APP_DEBUG=true
FRONTEND_BASE_URL=http://localhost:8080

SERVER_PORT=8080
SERVER_CORS_ORIGINS=http://localhost:8080
SERVER_READ_HEADER_TIMEOUT=10s
SERVER_RATE_LIMIT_ENABLED=true
SERVER_RATE_LIMIT_REQUESTS=20
SERVER_RATE_LIMIT_BURST=40

QUEUE_CONCURRENCY=10
QUEUE_STRICT=true
QUEUE_METRICS_ENABLED=true

LOG_LEVEL=info
LOG_FORMAT=json

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=gsk

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=go_starter_kit
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5

HASH_DRIVER=argon2id
HASH_ARGON2_MEMORY=65536
HASH_ARGON2_ITERATION=3
HASH_ARGON2_PARALLELISM=1
HASH_BCRYPT_COST=10

JWT_ACCESS_SECRET=secret_key
JWT_REFRESH_SECRET=secret_key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=168h

MAIL_DRIVER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_TLS_MODE=starttls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=test@example.com
MAIL_FROM_NAME=Go API Starter Kit

OTEL_ENABLED=true
OTEL_SERVICE_NAME=go-starter-kit
OTEL_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER_RATIO=1.0
OTEL_EXPORT_TIMEOUT=5s

GRAFANA_SERVICE_ACCOUNT_TOKEN=your_token_here
